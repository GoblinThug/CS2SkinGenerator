{
  "name": "cs2-skin-generator",
  "version": "v1.1.1",
  "author": "Goblin_Thug",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0"
  },
  "build": {
    "appId": "com.goblinthug.cs2skingenerator",
    "productName": "CS2 Skin Generator",
    "win": {
      "icon": "src/assets/icon.ico",
      "target": "nsis"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "maintainer": "goblinthug <goblin.thug@mail.ru>"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "GoblinThug",
        "repo": "cs2-skin-generator"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
